# ─── Banco de dados ───────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/azzo?currentSchema=assistant_app
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ─── Backend principal ────────────────────────────────────────────────────────
# URL do azzo-agenda-pro (deve estar rodando antes do assistant-api)
AGENDA_PRO_API_URL=http://localhost:8080
# Chave compartilhada entre os dois backends para chamadas internas seguras
INTERNAL_API_KEY=__change_me__

# ─── Agente LLM ───────────────────────────────────────────────────────────────
# true  = LLM conduz toda a conversa (recomendado)
# false = máquina de estados Java legada (fallback sem LLM)
ASSISTANT_AGENT_ENABLED=true

# ─── Groq API ─────────────────────────────────────────────────────────────────
# Groq é o provedor LLM primário — ultra rápido (~1s) e com free tier generoso.
# Documentação: https://console.groq.com/docs
#
# true  = usa Groq como provider principal (recomendado em produção)
# false = pula Groq e vai direto para Ollama local
GROQ_ENABLED=true
#
# Chave de API — obtenha gratuitamente em: https://console.groq.com/keys
GROQ_API_KEY=__set_in_prod__
#
# URL base da API do Groq — não altere, a menos que Groq mude o endpoint
GROQ_BASE_URL=https://api.groq.com
#
# Modelo utilizado pelo Groq:
#   llama-3.1-8b-instant    → rápido, barato (~$0.05/M tokens), ideal para produção
#   llama-3.3-70b-versatile → melhor qualidade, mais caro (~$0.59/M tokens)
#   gemma2-9b-it            → alternativa leve do Google
# Lista completa: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.1-8b-instant
#
# Limite diário de requisições antes de fazer fallback para Ollama.
# Free tier do Groq = 14.400 req/dia. Valor abaixo disso como margem de segurança.
GROQ_DAILY_LIMIT=12000
#
# Timeout de leitura em ms (Groq responde em ~1s, mas 30s é seguro para picos)
GROQ_READ_TIMEOUT_MS=30000

# ─── Ollama (fallback local) ──────────────────────────────────────────────────
# Usado quando Groq está desativado, indisponível ou atingiu o limite diário.
# Requer Docker rodando: docker compose -f docker-compose-ollama.yml up -d
#
# true  = Ollama disponível como fallback
# false = sem fallback local (retorna mensagem de erro amigável ao usuário)
OLLAMA_ENABLED=true
#
# URL do container Ollama
#   Local (dev): http://localhost:11434
#   Docker Compose (prod): http://ollama-llm:11434
OLLAMA_BASE_URL=http://ollama-llm:11434
#
# Modelo carregado no Ollama — criado pelo inicio-ollhama.bat
#   azzo-assistant-llama32  → llama3.2:3b (recomendado, ~2GB RAM)
#   azzo-assistant          → gemma2:2b (mais leve, ~1.6GB RAM)
OLLAMA_MODEL=azzo-assistant-llama32

# ─── Conversa ─────────────────────────────────────────────────────────────────
# Tempo de inatividade (em minutos) antes de limpar o histórico da conversa.
# Após esse tempo sem mensagens, o contexto é deletado do banco.
ASSISTANT_CONVERSATION_TTL_MINUTES=120
